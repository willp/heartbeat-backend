### Set up your .env file

# Create a .env file in the root project directory and add the following content, customized for your
# specific installation.

### TODO: Django create superuser step

# I haven't yet documented a complete from-scratch installation, so the initial
# sqlite database creation step is not here yet.

# TL;DR Run manage.py 
###


# --- 🔐 Security Settings ---
# Generate a random string: python3 -c 'import secrets; print(secrets.token_urlsafe(50))'
DJANGO_SECRET_KEY=change-me-to-something-very-long-and-random

# Comma-separated list of domains/IPs that can access this server
# Example: hb.example.com,192.168.1.50,localhost
DJANGO_ALLOWED_HOSTS=localhost

# Set to True only for local troubleshooting. Never use True in production!
DJANGO_DEBUG=False

# --- 📁 Database & Paths ---
# Absolute path to your SQLite database file
HEARTBEAT_DB_PATH=/data/hbdb.sqlite3

# (Optional) If you use an encrypted SQLite build, provide the key here
# HEARTBEAT_DB_KEY=your-sqlite-encryption-password

# --- 🌐 Network Settings ---
# The port the UDP and HTTP server will bind to inside the container
HEARTBEAT_PORT=8333

# --- 🧪 Timezones ---
TZ=America/Los_Angeles
